# Agent Commercial Contract - Environment Configuration

# ===== General Settings =====
NODE_ENV=development
LOG_LEVEL=info

# ===== Database =====
# Path to SQLite database (if using persistent storage)
DATABASE_PATH=./data/contracts.db

# ===== Security =====
# Encryption key for sensitive data (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your_encryption_key_here

# JWT secret for API authentication (if using REST API)
JWT_SECRET=your_jwt_secret_here

# ===== Contract Defaults =====
DEFAULT_CURRENCY=USD
DEFAULT_JURISDICTION=US
AUTO_ESCROW=false

# ===== Arbitration =====
# Default arbitrator agent ID (optional)
DEFAULT_ARBITRATOR=

# Arbitration timeout in days
ARBITRATION_TIMEOUT=30

# ===== Payment Gateway (Future Integration) =====
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ===== Blockchain (Future Integration) =====
ETHEREUM_RPC_URL=
ETHEREUM_PRIVATE_KEY=
SMART_CONTRACT_ADDRESS=

# ===== Webhooks =====
# Enable webhooks for contract events
WEBHOOKS_ENABLED=false
WEBHOOK_SECRET=

# ===== API Configuration =====
API_PORT=3000
API_HOST=0.0.0.0
CORS_ORIGIN=*

# ===== Notification Settings =====
NOTIFICATIONS_ENABLED=false
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_FROM=

# ===== Feature Flags =====
ENABLE_BLOCKCHAIN=false
ENABLE_CRYPTO_PAYMENTS=false
ENABLE_AI_ARBITRATION=false
ENABLE_TEMPLATES_MARKETPLACE=false
